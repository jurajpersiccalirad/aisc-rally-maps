{
  "name": "aisc-rally-maps",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Browser-based converter: KMZ/KML/GPX rally maps → Calirad AISC format.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit && tsc -p amplify/tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest --passWithNoTests",
    "sandbox": "ampx sandbox",
    "sandbox:delete": "ampx sandbox delete",
    "deploy": "ampx pipeline-deploy --branch $AWS_BRANCH --app-id $AWS_APP_ID",
    "seed:admin": "tsx amplify/seed/seed-admin.ts",
    "seed:dev": "tsx amplify/seed/seed-dev-users.ts"
  },
  "dependencies": {
    "@tmcw/togeojson": "^5.8.1",
    "@turf/turf": "^7.1.0",
    "aws-amplify": "^6.17.0",
    "bcryptjs": "^3.0.3",
    "fast-xml-parser": "^4.5.0",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "nanoid": "^5.0.7",
    "polygon-clipping": "^0.15.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.22.0",
    "@aws-amplify/backend-cli": "^1.8.2",
    "@aws-sdk/client-cognito-identity-provider": "^3.1045.0",
    "@eslint/js": "^9.14.0",
    "@types/aws-lambda": "^8.10.161",
    "@types/bcryptjs": "^2.4.6",
    "@types/file-saver": "^2.0.7",
    "@types/leaflet": "^1.9.14",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "aws-cdk-lib": "^2.253.1",
    "constructs": "^10.6.0",
    "eslint": "^9.14.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
